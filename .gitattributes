# Los scripts de shell y el entrypoint del worker corren en contenedores Linux:
# deben conservar finales de línea LF aunque se editen en Windows (CRLF rompe el
# shebang y da "bad interpreter" dentro del contenedor).
*.sh    text eol=lf
Dockerfile text eol=lf

# Normalización general de texto (LF en el repo).
* text=auto
